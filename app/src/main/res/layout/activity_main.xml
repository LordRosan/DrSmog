<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFB6C1">

    <Button
        android:id="@+id/buttonCamera"
        android:layout_width="250dp"
        android:layout_height="100dp"
        android:text="拍照/上传"
        android:background="@drawable/home_button_shape"
        android:textColor="#FFFFFF"
        android:textSize="20dp"
        android:layout_marginBottom="16dp"
        android:drawableLeft="@drawable/ic_action_home_photo_camera"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/buttonHistory"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintVertical_bias="0.5" />

    <Button
        android:id="@+id/buttonHistory"
        android:layout_width="250dp"
        android:layout_height="100dp"
        android:text="历史信息"
        android:background="@drawable/home_button_shape"
        android:textColor="#FFFFFF"
        android:textSize="20dp"
        android:layout_marginBottom="16dp"
        android:drawableLeft="@drawable/ic_action_home_photo_history"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/buttonCamera"
        app:layout_constraintBottom_toTopOf="@id/buttonAbout" />

    <Button
        android:id="@+id/buttonAbout"
        android:layout_width="250dp"
        android:layout_height="100dp"
        android:text="关于"
        android:background="@drawable/home_button_shape"
        android:textColor="#FFFFFF"
        android:textSize="20dp"
        android:drawableLeft="@drawable/ic_action_home_photo_about"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/buttonHistory"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

